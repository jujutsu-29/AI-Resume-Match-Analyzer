generator client {
  provider = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  extensions = [vector]
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          String    @default("USER") // USER, ADMIN
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  resumes       Resume[]
  usages        AiUsage[]
}

model Resume {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  filename      String
  fileUrl       String?
  textContent   String?   @db.Text
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  analyses      Analysis[]
  embeddings    Embedding[]
  skills        ResumeSkill[]
}

model JobDescription {
  id            String    @id @default(cuid())
  title         String
  company       String?
  textContent   String    @db.Text
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  analyses      Analysis[]
  skills        JobSkill[]
  embeddings    Embedding[]
}

model Analysis {
  id               String    @id @default(cuid())
  resumeId         String
  jobDescriptionId String
  
  resume           Resume          @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  jobDescription   JobDescription  @relation(fields: [jobDescriptionId], references: [id], onDelete: Cascade)

  atsScore         Float     @default(0)
  technicalScore   Float     @default(0)
  aiMlScore        Float     @default(0)
  
  missingKeywords  String[]
  missingSkills    String[]
  
  improvementSuggestions String[]
  strengths        String[]
  weaknesses       String[]
  
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model Embedding {
  id               String    @id @default(cuid())
  content          String    @db.Text
  vector           Unsupported("vector(1536)")?
  
  resumeId         String?
  resume           Resume?   @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  
  jobDescriptionId String?
  jobDescription   JobDescription? @relation(fields: [jobDescriptionId], references: [id], onDelete: Cascade)

  createdAt        DateTime  @default(now())
}

model Skill {
  id            String    @id @default(cuid())
  name          String    @unique
  category      String?   // Languages, Frameworks, Cloud, Databases, AI/ML
  
  resumeSkills  ResumeSkill[]
  jobSkills     JobSkill[]
}

model ResumeSkill {
  id        String   @id @default(cuid())
  resumeId  String
  skillId   String
  
  resume    Resume   @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  skill     Skill    @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([resumeId, skillId])
}

model JobSkill {
  id               String   @id @default(cuid())
  jobDescriptionId String
  skillId          String
  
  jobDescription   JobDescription @relation(fields: [jobDescriptionId], references: [id], onDelete: Cascade)
  skill            Skill          @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([jobDescriptionId, skillId])
}

model AiUsage {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  operation     String    // e.g. "resume_extraction", "embedding_generation"
  tokensUsed    Int       @default(0)
  cost          Float     @default(0)
  processingTimeMs Int    @default(0)

  createdAt     DateTime  @default(now())
}
